    "\n",
    "    drag=0.5*1.225*v0**2*cd \n",
    "    dragx=drag*cos_theta \n",
    "    dragy=drag*sin_theta\n",
    "\n",
    "    vx1=vx0-dragx*dt\n",
    "    vy1=vy0-(9.8+dragy)*dt \n",
    "    x1=x0+(vx0+vx1)/2.0*dt \n",
    "    y1=y0+(vy0+vy1)/2.0*dt \n",
    "    new_states=ca.vertcat(vx1,vy1,x1,y1)\n",
    "    return new_states\n",
    "\n",
    "def gen_cafunc():\n",
    "    # x0=ca.GenSX_sym(\"x\")\n",
